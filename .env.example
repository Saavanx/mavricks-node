# Base URL used for payment success/cancel redirect (no trailing slash)
APP_BASE_URL=https://your-domain.com

# Neon Postgres
DATABASE_URL=postgres://user:password@ep-xxxxxx.region.aws.neon.tech/neondb?sslmode=require

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx

# Stripe (optional if enabled)
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_SECRET_KEY=sk_live_xxxxx

# PhonePe (optional if enabled)
PHONEPE_CLIENT_ID=your_phonepe_client_id
PHONEPE_CLIENT_VERSION=1
PHONEPE_CLIENT_SECRET=your_phonepe_client_secret
PHONEPE_ENV=UAT

# MSG91 (OTP + WhatsApp + Email)
MSG91_AUTH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MSG91_BASE_URL=https://control.msg91.com
MSG91_OTP_TEMPLATE_ID=xxxxxxxxxxxxxxxxxxxxxxxx
MSG91_OTP_LENGTH=6
MSG91_OTP_EXPIRY_MINUTES=10
MSG91_WHATSAPP_FLOW_ID=xxxxxxxxxxxxxxxxxxxxxxxx
MSG91_EMAIL_FLOW_ID=xxxxxxxxxxxxxxxxxxxxxxxx
MSG91_OWNER_WHATSAPP_FLOW_ID=xxxxxxxxxxxxxxxxxxxxxxxx
MSG91_OWNER_EMAIL_FLOW_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# Optional fallback providers (used only if MSG91 flow IDs are missing)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=Mavricks <bookings@your-domain.com>
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Owner alerts for contact/reservation
OWNER_ALERT_EMAIL=owner@your-domain.com
OWNER_ALERT_WHATSAPP=+919793711154

# Optional rate limit for contact/reservation APIs
CONTACT_RATE_LIMIT_WINDOW_SEC=60
CONTACT_RATE_LIMIT_MAX=8

# Optional: protect admin settings endpoint
ADMIN_DASHBOARD_TOKEN=change-me
